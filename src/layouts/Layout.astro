---
import "../styles/global.css";
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<!-- Favicons & Manifest -->
		<link
			rel="icon"
			type="image/png"
			sizes="32x32"
			href="/favicon-32x32.png"
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="16x16"
			href="/favicon-16x16.png"
		/>
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/apple-touch-icon.png"
		/>
		<link rel="manifest" href="/manifest.json" />
		<meta name="theme-color" content="#eab308" />
		<meta name="generator" content={Astro.generator} />

		<!-- SEO Meta Tags -->
		<title>Renotech | Especialistas en repuestos automotrices</title>
		<meta
			name="description"
			content="Repuestos originales y alternativos para Renault, Mazda, Ford y Peugeot. Stock inmediato y envíos a toda Bolivia."
		/>
		<meta
			name="keywords"
			content="repuestos, renault, mazda, ford, peugeot, accesorios, motor, suspensión, frenos, bolivia, renotech, repuestos en sucre"
		/>
		<meta name="author" content="Renotech" />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href="https://renotech.lat/" />

		<!-- Open Graph / Social (Facebook, WhatsApp) -->
		<meta property="og:type" content="website" />
		<meta
			property="og:title"
			content="Renotech | Especialistas en repuestos automotrices"
		/>
		<meta
			property="og:description"
			content="Repuestos originales y alternativos para Renault, Mazda, Ford y Peugeot. Stock inmediato y envíos a toda Bolivia."
		/>
		<meta property="og:image" content="https://renotech.lat/logo.png" />
		<meta property="og:url" content="https://renotech.lat/" />
		<meta property="og:site_name" content="Renotech" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta
			name="twitter:title"
			content="Renotech | Especialistas en repuestos automotrices"
		/>
		<meta
			name="twitter:description"
			content="Repuestos originales y alternativos para Renault, Mazda, Ford y Peugeot. Stock inmediato y envíos a toda Bolivia."
		/>
		<meta name="twitter:image" content="https://renotech.lat/logo.png" />

		<!-- JSON-LD LocalBusiness -->
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "AutoPartsStore",
				"name": "Renotech",
				"image": "https://renotech.lat/logo.png",
				"@id": "https://renotech.lat",
				"url": "https://renotech.lat",
				"telephone": "+59164727700",
				"priceRange": "$$",
				"address": {
					"@type": "PostalAddress",
					"streetAddress": "Nuestra Señora de La Paz, Rotonda Rotary",
					"addressLocality": "Sucre",
					"addressRegion": "Chuquisaca",
					"postalCode": "0000",
					"addressCountry": "BO"
				},
				"geo": {
					"@type": "GeoCoordinates",
					"latitude": -19.027662,
					"longitude": -65.245666
				}
			}
		</script>

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap"
			rel="stylesheet"
		/>

		<style>
			body {
				font-family: "Inter", sans-serif;
			}
		</style>
	</head>
	<body
		class="bg-gray-50 text-slate-900 min-h-screen selection:bg-yellow-500 selection:text-black relative pt-[104px] lg:pt-[112px]"
	>
		<slot />

		<!-- Sticky WhatsApp Button -->
		<a
			href="https://wa.me/59164727700?text=Hola%20Renotech%2C%20necesito%20cotizar%20un%20repuesto"
			target="_blank"
			rel="noopener noreferrer"
			class="fixed bottom-6 right-6 z-50 bg-green-500 hover:bg-green-400 text-white p-4 rounded-full shadow-2xl transition-all hover:scale-110 active:scale-95 group flex items-center justify-center"
			aria-label="Contactar por WhatsApp"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				width="28"
				height="28"
				viewBox="0 0 24 24"
				fill="currentColor"
			>
				<path
					d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"
				></path>
			</svg>
			<span
				class="absolute -top-10 scale-0 group-hover:scale-100 transition-all bg-slate-800 text-white text-xs py-1 px-3 rounded-lg border border-slate-700 whitespace-nowrap"
			>
				¡Escríbenos ahora!
			</span>
		</a>
	</body>
</html>

---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
    <Navbar />
    <main
        class="min-h-[85vh] flex items-center justify-center pt-32 pb-24 relative overflow-hidden"
    >
        <!-- Background elements matching Hero -->
        <div
            class="absolute inset-0 w-full h-full z-0 overflow-hidden bg-gray-100"
        >
            <div class="absolute inset-0 bg-white/85 backdrop-blur-[2px]"></div>
            <div
                class="absolute inset-0 bg-gradient-to-b from-transparent via-white/50 to-white"
            >
            </div>
        </div>

        <div class="relative z-10 text-center px-4 max-w-2xl mx-auto">
            <div class="inline-flex items-center justify-center mb-6">
                <div
                    class="bg-yellow-100 text-yellow-600 p-4 rounded-full shadow-inner animate-pulse"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="48"
                        height="48"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="lucide lucide-triangle-alert"
                        ><path
                            d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"
                        ></path><path d="M12 9v4"></path><path d="M12 17h.01"
                        ></path></svg
                    >
                </div>
            </div>
            <h1
                class="text-8xl sm:text-9xl font-black text-slate-900 tracking-tighter drop-shadow-sm"
            >
                404
            </h1>
            <h2 class="text-2xl sm:text-3xl font-bold text-slate-800 mt-2 mb-6">
                Pieza no encontrada
            </h2>
            <p class="text-slate-600 mb-10 text-lg leading-relaxed font-medium">
                Al parecer te has desviado de la ruta. La página o repuesto que
                estás buscando ya no existe o ha sido movida de nuestro
                inventario principal.
            </p>
            <div
                class="flex flex-col sm:flex-row items-center justify-center gap-4"
            >
                <a
                    href="/"
                    class="w-full sm:w-auto flex items-center justify-center gap-2 bg-yellow-500 hover:bg-yellow-400 text-slate-950 font-bold uppercase tracking-widest text-sm px-8 py-4 rounded-2xl transition-transform hover:scale-105 active:scale-95 shadow-xl shadow-yellow-500/20"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path
                            d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
                        ></path><polyline points="9 22 9 12 15 12 15 22"
                        ></polyline></svg
                    >
                    Volver al Taller
                </a>
                <a
                    href="https://wa.me/59164727700?text=Hola%20Renotech%2C%20estaba%20buscando%20un%20repuesto%20pero%20no%20lo%20encontr%C3%A9%20en%20la%20p%C3%A1gina"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-full sm:w-auto text-slate-700 bg-white hover:bg-slate-50 border-2 border-slate-200 px-8 py-4 rounded-2xl font-bold uppercase tracking-widest text-sm transition-all shadow-sm hover:border-yellow-500 inline-flex items-center justify-center gap-2"
                >
                    Cotizar Directo
                </a>
            </div>
        </div>
    </main>
    <Footer />
</Layout>

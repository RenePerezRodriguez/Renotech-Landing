---
// src/components/Footer.astro
const quickLinks = [
    { name: "Inicio", href: "#inicio" },
    { name: "Marcas", href: "#marcas" },
    { name: "Catálogo", href: "#catalogo" },
    { name: "¿Por qué elegirnos?", href: "#nosotros" },
];
---

<footer
    id="contacto"
    class="bg-slate-950 pt-24 pb-12 border-t border-slate-900 relative z-10 selection:bg-yellow-500 selection:text-black overflow-hidden"
>
    <!-- Background subtle glow -->
    <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-2xl h-1/2 bg-yellow-500/5 blur-[120px] pointer-events-none"
    >
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-8 mb-16"
        >
            <!-- Column 1: Company Info & Live Status -->
            <div
                class="lg:col-span-3 flex flex-col items-start text-left reveal-footer flex-shrink-0"
            >
                <a
                    href="/"
                    class="mb-6 font-black text-3xl tracking-tighter text-white inline-flex items-center gap-3 group"
                >
                    <div
                        class="w-10 h-10 bg-yellow-500 rounded-xl flex items-center justify-center -rotate-3 group-hover:rotate-0 transition-transform shadow-[0_0_20px_rgba(234,179,8,0.3)]"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="text-black w-6 h-6"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="3"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"
                            ></path></svg
                        >
                    </div>
                    RENOTECH
                </a>

                <div
                    class="flex items-center gap-2 mb-6 bg-slate-900/80 border border-slate-800 rounded-full py-1.5 px-3"
                >
                    <span class="relative flex h-2.5 w-2.5">
                        <span
                            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"
                        ></span>
                        <span
                            class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-500"
                        ></span>
                    </span>
                    <span
                        class="text-gray-300 text-xs font-semibold tracking-wide uppercase"
                        >Soporte Continuo</span
                    >
                </div>

                <p class="text-gray-400 text-sm leading-relaxed mb-8">
                    Tu aliado estratégico en repuestos automotrices. Calidad,
                    rapidez y confianza garantizada en cada compra.
                </p>

                <!-- Custom Social Buttons -->
                <div class="flex gap-4">
                    <a
                        href="#"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="w-11 h-11 rounded-full bg-slate-900 border border-slate-800 flex items-center justify-center text-gray-500 hover:text-white hover:border-blue-500 hover:bg-blue-600 transition-all hover:-translate-y-1 shadow-lg group"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            class="group-hover:scale-110 transition-transform duration-300"
                            ><path
                                d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"
                            ></path></svg
                        >
                    </a>
                    <a
                        href="https://wa.me/59164727700?text=Hola%20Renotech"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="w-11 h-11 rounded-full bg-slate-900 border border-slate-800 flex items-center justify-center text-gray-500 hover:text-white hover:border-green-500 hover:bg-green-600 transition-all hover:-translate-y-1 shadow-lg group"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="22"
                            height="22"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            class="group-hover:scale-110 transition-transform duration-300"
                            ><path
                                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"
                            ></path></svg
                        >
                    </a>
                </div>
            </div>

            <!-- Column 2: Quick Links -->
            <div
                class="lg:col-span-2 flex flex-col items-start lg:pl-4 reveal-footer"
                style="transition-delay: 100ms;"
            >
                <h4
                    class="text-white font-black uppercase tracking-tight text-lg mb-6 flex items-center gap-2"
                >
                    <span
                        class="w-1.5 h-1.5 bg-yellow-500 rounded-full inline-block"
                    ></span>
                    Navegación
                </h4>
                <nav class="flex flex-col gap-4 w-full">
                    {
                        quickLinks.map((link) => (
                            <a
                                href={link.href}
                                class="text-gray-400 font-medium hover:text-white transition-colors text-sm group relative inline-block w-fit"
                            >
                                {link.name}
                                <span class="absolute -bottom-1 left-0 w-0 h-[2px] bg-yellow-500 transition-all duration-300 group-hover:w-full rounded-full" />
                            </a>
                        ))
                    }
                </nav>
            </div>

            <!-- Column 3: Glassmorphism Form -->
            <div
                class="lg:col-span-3 reveal-footer"
                style="transition-delay: 200ms;"
            >
                <div
                    class="bg-slate-900/50 backdrop-blur-xl border border-slate-800 rounded-3xl p-6 lg:p-7 shadow-[0_20px_40px_-15px_rgba(0,0,0,0.5)] relative overflow-hidden group"
                >
                    <div
                        class="absolute inset-0 bg-yellow-500/5 transition-opacity opacity-0 group-hover:opacity-100 pointer-events-none"
                    >
                    </div>

                    <h4
                        class="text-white font-black uppercase tracking-tight text-xl mb-6 flex items-center gap-2"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="text-yellow-500"
                            ><path
                                d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
                            ></path><polyline points="14 2 14 8 20 8"
                            ></polyline><line x1="16" y1="13" x2="8" y2="13"
                            ></line><line x1="16" y1="17" x2="8" y2="17"
                            ></line><polyline points="10 9 9 9 8 9"
                            ></polyline></svg
                        >
                        Cotiza Rápido
                    </h4>

                    <form
                        class="space-y-4 relative z-10"
                        onsubmit="event.preventDefault(); window.open('https://wa.me/59164727700?text=' + encodeURIComponent('Hola Renotech, soy ' + document.getElementById('nombre').value + ' (' + document.getElementById('email').value + '). Quisiera cotizar: ' + document.getElementById('repuesto').value), '_blank');"
                    >
                        <div class="relative group/input">
                            <div
                                class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-500 group-focus-within/input:text-yellow-500 transition-colors"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2.5"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    ><path
                                        d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"
                                    ></path><circle cx="12" cy="7" r="4"
                                    ></circle></svg
                                >
                            </div>
                            <input
                                type="text"
                                id="nombre"
                                placeholder="Nombre completo"
                                required
                                class="w-full bg-slate-950 border border-slate-700/50 rounded-xl pl-10 pr-4 py-3 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-yellow-500 focus:ring-1 focus:ring-yellow-500/50 transition-all shadow-inner"
                            />
                        </div>

                        <div class="relative group/input">
                            <div
                                class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-500 group-focus-within/input:text-yellow-500 transition-colors"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2.5"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    ><rect
                                        x="2"
                                        y="4"
                                        width="20"
                                        height="16"
                                        rx="2"></rect><path
                                        d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"
                                    ></path></svg
                                >
                            </div>
                            <input
                                type="email"
                                id="email"
                                placeholder="Correo electrónico"
                                required
                                class="w-full bg-slate-950 border border-slate-700/50 rounded-xl pl-10 pr-4 py-3 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-yellow-500 focus:ring-1 focus:ring-yellow-500/50 transition-all shadow-inner"
                            />
                        </div>

                        <div class="relative group/input">
                            <div
                                class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-500 group-focus-within/input:text-yellow-500 transition-colors"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2.5"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    ><circle cx="11" cy="11" r="8"
                                    ></circle><line
                                        x1="21"
                                        y1="21"
                                        x2="16.65"
                                        y2="16.65"></line></svg
                                >
                            </div>
                            <input
                                type="text"
                                id="repuesto"
                                placeholder="¿Qué necesitas?"
                                required
                                class="w-full bg-slate-950 border border-slate-700/50 rounded-xl pl-10 pr-4 py-3 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-yellow-500 focus:ring-1 focus:ring-yellow-500/50 transition-all shadow-inner"
                            />
                        </div>

                        <button
                            type="submit"
                            class="w-full bg-gradient-to-r from-yellow-500 to-yellow-400 hover:from-yellow-400 hover:to-yellow-300 text-slate-900 font-black uppercase text-xs tracking-widest py-3.5 rounded-xl transition-all active:scale-95 shadow-[0_10px_20px_-10px_rgba(234,179,8,0.5)] mt-1 flex justify-center items-center gap-2"
                        >
                            Cotizar por WhatsApp
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="14"
                                height="14"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="3"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><line x1="22" y1="2" x2="11" y2="13"
                                ></line><polygon
                                    points="22 2 15 22 11 13 2 9 22 2"
                                ></polygon></svg
                            >
                        </button>
                    </form>
                </div>
            </div>

            <!-- Column 4: Cinematic Map -->
            <div
                class="lg:col-span-4 rounded-3xl overflow-hidden border border-slate-800 isolate bg-slate-900 flex flex-col hover:border-slate-700 transition-colors min-h-[300px] reveal-footer shadow-[0_20px_40px_-15px_rgba(0,0,0,0.5)]"
                style="transition-delay: 300ms;"
            >
                <div class="p-6 pb-4">
                    <h4
                        class="text-white font-black uppercase tracking-tight text-lg mb-2 flex items-center gap-2"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="text-yellow-500"
                            ><path
                                d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"
                            ></path><circle cx="12" cy="10" r="3"></circle></svg
                        >
                        Nuestra Ubicación
                    </h4>
                    <p class="text-slate-400 text-xs">
                        Visita nuestra tienda para una atención personalizada.
                    </p>
                </div>
                <!-- Interactive Map Area -->
                <div
                    class="flex-grow w-full h-full relative p-2 pt-0 group/map cursor-pointer"
                >
                    <div
                        class="w-full h-full rounded-[1.2rem] overflow-hidden bg-slate-950 relative"
                    >
                        <!-- Glass overlay receiver (fades on hover) -->
                        <div
                            class="absolute inset-0 z-10 bg-slate-900/40 pointer-events-none group-hover/map:opacity-0 transition-opacity duration-300"
                        >
                        </div>

                        <iframe
                            src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d3771.82!2d-65.245666!3d-19.027662!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTnCsDAxJzM5LjYiUyA2NcKwMTQnNDQuNCJX!5e0!3m2!1ses!2sbo!4v1700000000000!5m2!1ses!2sbo"
                            width="100%"
                            height="100%"
                            class="border-0 invert-[.95] grayscale contrast-125 opacity-70 group-hover/map:opacity-100 group-hover/map:invert-0 group-hover/map:grayscale-0 group-hover/map:contrast-100 transition-all duration-700 ease-in-out relative z-0"
                            allowfullscreen=""
                            loading="lazy"
                            referrerpolicy="no-referrer-when-downgrade"
                        >
                        </iframe>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer Bottom: Copyright & Legal inside Flex + Back to top button -->
        <div
            class="pt-8 border-t border-slate-800 flex flex-col md:flex-row justify-between items-center gap-6 reveal-footer"
            style="transition-delay: 400ms;"
        >
            <div
                class="flex flex-col gap-1.5 items-center md:items-start text-center md:text-left"
            >
                <p
                    class="text-slate-500 text-xs font-semibold tracking-wider uppercase"
                >
                    &copy; {new Date().getFullYear()} RENOTECH.<span
                        class="lowercase text-slate-600 font-medium"
                    >
                        Todos los derechos reservados.</span
                    >
                    <span class="mx-2 text-slate-700">|</span>
                    <a
                        href="/privacidad"
                        class="hover:text-yellow-500 transition-colors uppercase font-bold text-[10px] tracking-widest"
                        >Aviso de Privacidad</a
                    >
                </p>
                <p
                    class="text-slate-600 text-[10px] uppercase tracking-widest font-bold"
                >
                    Desarrollado y diseñado por <a
                        href="https://SafeSoft.tech"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-yellow-500 hover:text-white transition-colors"
                        >SafeSoft.tech</a
                    > y <a
                        href="https://DesarrolloWebBolivia.com"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-yellow-500 hover:text-white transition-colors"
                        >DesarrolloWebBolivia.com</a
                    >
                </p>
            </div>
            <div class="flex items-center gap-6">
                <!-- Back to Top Button -->
                <button
                    id="scrollToTopBtn"
                    class="w-10 h-10 rounded-full bg-slate-900 border border-slate-700 flex items-center justify-center text-yellow-500 hover:text-slate-900 hover:bg-yellow-500 hover:border-yellow-500 transition-all active:scale-95 shadow-lg group mr-2"
                    aria-label="Volver arriba"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="group-hover:-translate-y-1 transition-transform"
                        ><path d="m18 15-6-6-6 6"></path></svg
                    >
                </button>
            </div>
        </div>
    </div>
</footer>

<script is:inline>
    // Reveal Observer for Footer
    document.addEventListener("DOMContentLoaded", () => {
        const revealFooterItems = document.querySelectorAll(".reveal-footer");

        // Initial setup for footer reveals
        revealFooterItems.forEach((item) => {
            item.classList.add(
                "opacity-0",
                "translate-y-8",
                "transition-all",
                "duration-1000",
                "ease-out",
            );
        });

        const observerOptions = {
            root: null,
            rootMargin: "0px",
            threshold: 0.1,
        };

        const footerObserver = new IntersectionObserver((entries, observer) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    entry.target.classList.remove("opacity-0", "translate-y-8");
                    entry.target.classList.add("opacity-100", "translate-y-0");
                    observer.unobserve(entry.target);
                }
            });
        }, observerOptions);

        revealFooterItems.forEach((item) => {
            footerObserver.observe(item);
        });

        // Back to top logic
        const scrollToTopBtn = document.getElementById("scrollToTopBtn");
        if (scrollToTopBtn) {
            scrollToTopBtn.addEventListener("click", () => {
                window.scrollTo({
                    top: 0,
                    behavior: "smooth",
                });
            });
        }
    });
</script>

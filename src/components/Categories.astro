---
// src/components/Categories.astro
const categories = [
    {
        name: "Motor",
        items: ["Filtros y Correas", "Empaquetaduras", "Pistones y Anillos"],
        icon: `<path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />`,
        span: "md:col-span-2 lg:col-span-2",
        img: "https://images.unsplash.com/photo-1598460611756-320d57d74102?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3wxMTc3M3wwfDF8c2VhcmNofDV8fGNhciUyMGVuZ2luZXxlbnwwfHx8fDE3MjczODE1OTZ8MA&ixlib=rb-4.0.3&q=80&w=600"
    },
    {
        name: "Suspensión y Dirección",
        items: ["Amortiguadores", "Bandejas", "Terminales"],
        icon: `<path d="M8 3v3h8V3M8 18v3h8v-3M4 12h16M12 3v18" />`,
        span: "md:col-span-1 lg:col-span-1",
    },
    {
        name: "Sistema Eléctrico",
        items: ["Alternadores", "Sensores", "Bujías"],
        icon: `<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />`,
        span: "md:col-span-1 lg:col-span-1",
    },
    {
        name: "Sistema de Frenos",
        items: ["Pastillas", "Discos", "Cilindros"],
        icon: `<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><path d="M12 2v4M12 18v4M2 12h4M18 12h4"/>`,
        span: "md:col-span-1 lg:col-span-1",
    },
    {
        name: "Accesorios",
        items: ["Iluminación", "Fluidos", "Grapas"],
        icon: `<path d="m16 8 4-4m-4 4v8m0-8h4m-4 8 4 4m-4-4H4m12 0-4-4m4 4-4 4"/>`,
        span: "md:col-span-1 lg:col-span-1",
    },
];
---

<section id="catalogo" class="py-24 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="max-w-3xl mb-12">
        <h2 class="renotech-title mb-6">
            <span class="text-yellow-500">Categorías</span> Principales
        </h2>
        <p class="text-gray-600 text-lg leading-relaxed">
            Contamos con una amplia variedad de repuestos de alta calidad para mantenimiento y reparación. Explora nuestro inventario premium.
        </p>
    </div>

    <!-- 9. Fake Search Bar -->
    <div class="mb-14 max-w-3xl relative group">
        <div class="absolute inset-y-0 left-0 pl-5 flex items-center pointer-events-none text-gray-400 group-focus-within:text-yellow-500 transition-colors duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        </div>
        <input 
            type="text" 
            id="fake-search"
            class="block w-full pl-14 pr-36 py-5 bg-white border border-gray-200 rounded-2xl text-slate-900 placeholder-gray-400 focus:outline-none focus:ring-4 focus:ring-yellow-500/10 focus:border-yellow-500 transition-all font-medium md:text-lg shadow-sm hover:shadow-md"
            placeholder="¿Buscas una pieza exacta? Escríbela aquí..."
            onkeydown="if(event.key === 'Enter') { window.open('https://wa.me/59178888888?text=Hola,%20estoy%20buscando:%20' + encodeURIComponent(this.value), '_blank'); }"
        />
        <button 
            onclick="window.open('https://wa.me/59178888888?text=Hola,%20estoy%20buscando:%20' + encodeURIComponent(document.getElementById('fake-search').value), '_blank');"
            class="absolute inset-y-2 right-2 flex items-center bg-slate-900 text-white px-8 rounded-xl font-bold uppercase tracking-wider text-sm hover:bg-yellow-500 transition-colors shadow-lg"
        >
            Buscar
        </button>
    </div>

    <!-- 10. Bento Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
            categories.map((cat, index) => (
                <a
                    href={`https://wa.me/59178888888?text=Hola%20Renotech%2C%20necesito%20repuestos%20de%20la%20categor%C3%ADa%3A%20${cat.name}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class={`group relative flex flex-col justify-between overflow-hidden rounded-3xl bg-white shadow-sm p-8 text-left transition-all duration-500 hover:-translate-y-2 border border-gray-200 hover:border-yellow-500 hover:shadow-[0_20px_40px_-15px_rgba(234,179,8,0.3)] ${cat.span}`}
                    style={`animation-delay: ${index * 100}ms`}
                >
                    <!-- Background Glow Indicator -->
                    <span class="absolute inset-x-0 bottom-0 h-1 bg-gradient-to-r from-transparent via-yellow-500 to-transparent scale-x-0 opacity-0 group-hover:opacity-100 group-hover:scale-x-100 transition-all duration-700 ease-out"></span>

                    <div class="flex flex-col h-full transform transition-transform duration-500 group-hover:-translate-y-2">
                        <!-- Icon -->
                        <div class="w-16 h-16 rounded-2xl bg-gray-50 flex items-center justify-center text-yellow-500 mb-8 mt-2 group-hover:bg-yellow-500 group-hover:text-white transition-colors duration-300">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={cat.icon} />
                        </div>

                        <h3 class="font-black text-2xl lg:text-3xl uppercase tracking-tighter mb-4 text-slate-900 group-hover:text-yellow-500 transition-colors duration-300">
                            {cat.name}
                        </h3>

                        <!-- 5. Mini-Listas Desplegables -->
                        <ul class="text-gray-500 text-sm space-y-2 mb-4 font-medium tracking-wide flex-1">
                            {cat.items.map(item => (
                                <li class="flex items-center gap-2">
                                    <span class="w-1 h-1 rounded-full bg-yellow-500"></span>
                                    {item}
                                </li>
                            ))}
                        </ul>

                    </div>

                    <!-- 1. Hover Reveal CTA -->
                    <div class="mt-4 border-t border-gray-100 pt-4 overflow-hidden relative">
                         <div class="w-full h-0 max-h-0 opacity-0 group-hover:h-auto group-hover:max-h-20 group-hover:opacity-100 transform translate-y-4 group-hover:translate-y-0 text-yellow-500 text-xs md:text-sm font-bold uppercase tracking-widest flex items-center gap-2 transition-all duration-500 ease-out">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z" />
                            </svg>
                            Cotizar Repuestos
                            <svg xmlns="http://www.w3.org/2000/svg" class="ml-auto" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                        </div>
                    </div>
                </a>
            ))
        }
    </div>

    <!-- Global Floating CTA Bottom -->
    <div class="mt-16 text-center">
        <a
            href="https://wa.me/59178888888?text=Hola%20Renotech%2C%20busco%20un%20repuesto%20espec%C3%ADfico"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 bg-white border border-gray-200 hover:border-yellow-500 hover:shadow-[0_0_20px_rgba(234,179,8,0.2)] text-slate-900 px-8 py-4 rounded-2xl font-bold transition-all text-sm uppercase tracking-widest shadow"
        >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="text-green-500">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z" />
            </svg>
            ¿No encuentras tu repuesto? Escríbenos
        </a>
    </div>
</section>

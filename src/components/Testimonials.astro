---
const testimonials = [
    {
        name: "Carlos M.",
        role: "Taller Mecánico en Sucre",
        text: "Excelente servicio. Encontré repuestos originales para mi Renault Duster que no conseguía en ningún lado. Envío rápido y precios justos.",
        rating: 5,
    },
    {
        name: "María L.",
        role: "Propietaria de Peugeot 208",
        text: "La atención personalizada hace toda la diferencia. Me asesoraron perfectamente sobre las opciones de frenos para mi vehículo. 100% recomendados.",
        rating: 5,
    },
    {
        name: "Roberto S.",
        role: "Mecánico Automotriz en La Paz",
        text: "Ya llevo más de un año comprando repuestos con Renotech. Siempre tienen stock, las piezas son de calidad y los envíos llegan a tiempo.",
        rating: 5,
    },
];
---

<section class="py-20 lg:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
            <span
                class="text-yellow-500 font-bold uppercase tracking-widest text-sm"
                >Testimonios</span
            >
            <h2
                class="text-slate-900 font-black text-2xl md:text-3xl mt-2 uppercase"
            >
                Lo que dicen nuestros clientes
            </h2>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
            {
                testimonials.map((t) => (
                    <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:border-yellow-500/30 hover:shadow-lg transition-all duration-300 group">
                        {/* Stars */}
                        <div class="flex gap-1 mb-4">
                            {Array.from({ length: t.rating }).map(() => (
                                <svg
                                    class="w-5 h-5 text-yellow-500"
                                    fill="currentColor"
                                    viewBox="0 0 20 20"
                                >
                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                </svg>
                            ))}
                        </div>

                        {/* Quote */}
                        <p class="text-slate-600 leading-relaxed mb-6 italic">
                            "{t.text}"
                        </p>

                        {/* Author */}
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-yellow-500/10 flex items-center justify-center text-yellow-600 font-bold text-sm">
                                {t.name.charAt(0)}
                            </div>
                            <div>
                                <div class="font-bold text-slate-900 text-sm">
                                    {t.name}
                                </div>
                                <div class="text-xs text-slate-400">
                                    {t.role}
                                </div>
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>

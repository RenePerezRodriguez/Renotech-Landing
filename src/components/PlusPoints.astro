        class="relative w-full max-w-5xl mx-4 aspect-video rounded-3xl overflow-hidden shadow-[0_0_50px_rgba(0,0,0,0.5)] scale-95 transition-transform duration-500 ease-out"
        id="video-container"
    >
        <!-- Close Button -->

---
// src/components/Hero.astro
---

<section
    id="inicio"
    class="relative pt-32 pb-24 lg:pt-48 lg:pb-32 overflow-hidden flex flex-col items-center justify-center min-h-[90vh]"
>
    <!-- 1. Premium Background with Parallax -->
    <div class="absolute inset-0 w-full h-full z-0 overflow-hidden bg-gray-100">
        <div
            id="parallax-bg"
            class="absolute inset-0 w-full h-[120%] -top-[10%] bg-cover bg-center bg-no-repeat transition-transform duration-75 ease-out"
            style="background-image: url('https://images.unsplash.com/photo-1486262715619-67b85e0b08d3?q=80&w=2072&auto=format&fit=crop');"
        >
        </div>
        <!-- Light overlay to ensure text readability -->
        <div class="absolute inset-0 bg-white/85 backdrop-blur-[2px]"></div>
        <!-- Subtle radial gradient for focus -->
        <div
            class="absolute inset-0 bg-gradient-to-b from-transparent via-white/50 to-white"
        >
        </div>
    </div>

    <div
        class="relative z-10 text-center max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 w-full"
    >
        <!-- 5. Dynamic Badge -->
        <div class="flex items-center justify-center mb-8 animate-fade-in-up">
            <div
                class="inline-flex items-center gap-2 bg-white/80 backdrop-blur-md border border-gray-200/60 shadow-sm px-4 py-1.5 rounded-full text-xs font-bold text-slate-800 uppercase tracking-widest"
            >
                <span class="relative flex h-2.5 w-2.5">
                    <span
                        class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"
                    ></span>
                    <span
                        class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-500"
                    ></span>
                </span>
                Stock Inmediato Garantizado 2024
            </div>
        </div>

        <!-- 6. Typewriter Effect Title -->
        <h1
            class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black text-slate-900 mb-6 tracking-tight leading-[1.1] animate-fade-in-up"
            style="animation-delay: 100ms;"
        >
            El repuesto exacto para tu <br class="hidden sm:block" />
            <span
                class="text-transparent bg-clip-text bg-gradient-to-r from-yellow-500 to-yellow-600 relative inline-block min-w-[180px] sm:min-w-[280px] text-left"
            >
                <span id="typewriter" class="border-r-4 border-yellow-500 pr-1"
                    >Renault</span
                >
            </span>
        </h1>

        <p
            class="text-slate-600 text-lg md:text-xl mb-10 leading-relaxed max-w-2xl mx-auto animate-fade-in-up font-medium"
            style="animation-delay: 200ms;"
        >
            Piezas originales y alternativas premium. Envíos exprés a toda
            Bolivia con atención experta y personalizada.
        </p>

        <!-- 8 & 9. Dual CTAs + Microtext -->
        <div
            class="flex flex-col items-center gap-3 animate-fade-in-up"
            style="animation-delay: 300ms;"
        >
            <div
                class="flex flex-col sm:flex-row items-center justify-center gap-4 w-full sm:w-auto"
            >
                <!-- Primary WhatsApp CTA -->
                <div class="relative group w-full sm:w-auto">
                    <div
                        class="absolute inset-0 bg-green-400 rounded-2xl blur opacity-30 group-hover:opacity-60 transition-opacity duration-500 animate-pulse"
                    >
                    </div>
                    <a
                        href="https://wa.me/59164727700?text=Hola%20Renotech%2C%20necesito%20cotizar%20un%20repuesto"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="relative flex justify-center items-center gap-2 bg-green-500 hover:bg-green-600 text-white font-bold uppercase tracking-widest text-sm px-8 py-4 rounded-2xl transition-transform hover:scale-105 active:scale-95 shadow-xl shadow-green-500/20 w-full sm:w-auto"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                            ></path></svg
                        >
                        Cotizar Repuesto
                    </a>
                </div>

                <!-- Secondary Outline CTA -->
                <a
                    href="#catalogo"
                    class="w-full sm:w-auto text-slate-800 bg-white/50 hover:bg-white border-2 border-slate-200 hover:border-yellow-500 px-8 py-4 rounded-2xl font-bold transition-all duration-300 text-sm uppercase tracking-widest text-center shadow-sm backdrop-blur-sm"
                >
                    Explorar Catálogo
                </a>
            </div>
            <!-- Micro-text -->
            <div
                class="flex items-center gap-1.5 text-xs text-slate-500 font-medium mt-2"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-green-500"
                    ><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"
                    ></path><polyline points="22 4 12 14.01 9 11.01"
                    ></polyline></svg
                >
                Respuesta experta garantizada en menos de 5 minutos
            </div>
        </div>
    </div>
</section>

<style>
    .animate-fade-in-up {
        animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        opacity: 0;
        transform: translateY(20px);
    }

    @keyframes fadeInUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Blinking cursor for typewriter */
    @keyframes blink {
        0%,
        100% {
            border-color: transparent;
        }
        50% {
            border-color: #eab308;
        }
    }

    #typewriter.typing::after {
        content: "";
        border-right: 4px solid #eab308;
        animation: blink 1s step-end infinite;
        position: absolute;
        right: -8px;
        top: 10%;
        height: 80%;
    }
</style>

<script>
    // 3. Parallax Effect logic
    const parallaxBg = document.getElementById("parallax-bg");

    // Throttle scroll events
    let ticking = false;
    window.addEventListener(
        "scroll",
        () => {
            if (!ticking && parallaxBg) {
                window.requestAnimationFrame(() => {
                    const scrolled = window.scrollY;
                    // Move background slightly slower than scroll (parallax)
                    // Using transform instead of background-position for better performance
                    parallaxBg.style.transform = `translateY(${scrolled * 0.4}px)`;
                    ticking = false;
                });
                ticking = true;
            }
        },
        { passive: true },
    );

    // 6. Typewriter Effect logic
    const words = ["Renault", "Mazda", "Ford", "Peugeot"];
    const typewriterElement = document.getElementById("typewriter");

    let wordIndex = 0;
    let charIndex = words[0].length; // Start fully typed with the first word
    let isDeleting = false;
    let typeSpeed = 100;

    function type() {
        if (!typewriterElement) return;

        const currentWord = words[wordIndex];

        if (isDeleting) {
            // Remove a character
            typewriterElement.textContent = currentWord.substring(
                0,
                charIndex - 1,
            );
            charIndex--;
            typeSpeed = 50; // Faster when deleting
        } else {
            // Add a character
            typewriterElement.textContent = currentWord.substring(
                0,
                charIndex + 1,
            );
            charIndex++;
            typeSpeed = 150; // Slower when typing
        }

        // Logic to switch states
        if (!isDeleting && charIndex === currentWord.length) {
            // Finished typing the word, pause before deleting
            isDeleting = true;
            typeSpeed = 2000; // Wait 2s
            typewriterElement.classList.add("typing");
        } else if (isDeleting && charIndex === 0) {
            // Finished deleting, move to next word
            isDeleting = false;
            wordIndex = (wordIndex + 1) % words.length;
            typeSpeed = 500; // Small pause before typing new word
            typewriterElement.classList.remove("typing");
        }

        setTimeout(type, typeSpeed);
    }

    // Start the typewriter effect after initial animation delay (100ms) + 3s reading time
    setTimeout(() => {
        isDeleting = true;
        typewriterElement?.classList.add("typing");
        type();
    }, 3000);
</script>
